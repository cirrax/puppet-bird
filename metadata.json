{
  "name": "cirrax-bird",
  "version": "1.0.1",
  "author": "cirrax",
  "summary": "openvox/puppet module for bird2",
  "license": "GPL-3.0-or-later",
  "source": "https://github.com/cirrax/puppet-bird",
  "project_page": "https://github.com/cirrax/puppet-bird",
  "issues_url": "https://github.com/cirrax/puppet-bird/issues",
  "dependencies": [
    {
      "name": "puppetlabs/stdlib",
      "version_requirement": ">=3.0.0 < 10.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": [
        "10",
